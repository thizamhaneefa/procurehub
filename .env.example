# ===== ProcureHub environment variables =====
# In Netlify: Site configuration → Environment variables → add each of these.
# Locally: copy this file to ".env" and fill in real values (".env" is git-ignored).

# --- Database (Supabase → Connect dialog) ---
# DATABASE_URL = the "Transaction pooler" string (port 6543). Used at runtime by Netlify functions.
DATABASE_URL="postgresql://postgres.caaygnpenobyfuwordyd:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = the "Direct connection" string (port 5432). Used for creating tables / migrations.
DIRECT_URL="postgresql://postgres:YOUR-DB-PASSWORD@db.caaygnpenobyfuwordyd.supabase.co:5432/postgres"

# --- App session signing (use a long random string; generate your own) ---
SESSION_SECRET="change-me-to-a-long-random-secret"

# --- Supabase Storage (for uploaded bills / licenses / images) ---
SUPABASE_URL="https://caaygnpenobyfuwordyd.supabase.co"
# Secret / service_role key — Project Settings → API. KEEP PRIVATE. Set in Netlify only.
SUPABASE_SECRET_KEY=""
SUPABASE_BUCKET="uploads"
